# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=clinic_user
DB_PASSWORD=clinic_password
DB_NAME=clinic_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
