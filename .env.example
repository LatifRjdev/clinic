# App
APP_PORT=3000
APP_ENV=development
FRONTEND_URL=http://localhost:5173

# File Storage (MinIO / S3)
S3_ENDPOINT=localhost
S3_PORT=9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=clinic-files

# SMS (for notifications)
SMS_API_KEY=
SMS_SENDER=

# Email
SMTP_HOST=
